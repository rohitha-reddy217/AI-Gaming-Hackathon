    string githubLink
    string pptUrl
    string demoVideo
    string apkBuild
  }
  SUPPORT_TICKET {
    string ticketId
    string category
    string status
  }
  CHATBOT_LOG {
    string message
    string response
  }
  CAMPUS_AMBASSADOR {
    string referralCode
    number points
  }
  AUDIT_LOG {
    string action
    string target
  }
